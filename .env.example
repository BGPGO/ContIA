# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (bypass RLS) â€” server-side only, NUNCA expor no client.
# Usado por: pipeline de cortes (job-runner), cron de publish, drivers (LinkedIn, Instagram, etc.)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (geraÃ§Ã£o de conteÃºdo e imagens)
OPENAI_API_KEY=sk-...
# Claude (Anthropic) â€” usado no mÃ³dulo Gerador de Criativos IA
ANTHROPIC_API_KEY=sk-ant-...
# Meta / Instagram (Business Login)
META_APP_ID=
META_APP_SECRET=

# LinkedIn (Nivel 1 â€” auto-aprovados, sem CMA)
# Criar app em: https://www.linkedin.com/developers/apps/new
# Products a ativar (instantaneo): Sign In with LinkedIn using OpenID Connect + Share on LinkedIn
# Redirect URI a configurar no app LinkedIn: APP_URL/api/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# URL base da aplicacao (usado nos redirect URIs OAuth)
APP_URL=https://contia.bertuzzipatrimonial.com.br
NEXT_PUBLIC_APP_URL=https://contia.bertuzzipatrimonial.com.br

# Integracao CRM BGPGO (para drivers CRM e GreatPages)
CRM_API_URL=https://crm-api.bgpgo.com.br
CRM_ANALYTICS_API_KEY=

# Gemini (Google) — usado no pipeline de cortes de vídeo (Wave 3-5)
GEMINI_API_KEY=

# Cleanup de arquivos temporários de vídeo
# Gerar um segredo aleatório: openssl rand -hex 32
# Usar no header x-cleanup-secret ao chamar POST /api/admin/cleanup-video-tmp
# Configurar também no Coolify → Environment Variables
CLEANUP_SECRET=
# Shared secret para rotas /api/internal (CRM BGPGO consome)
META_ADS_INTERNAL_SECRET=
